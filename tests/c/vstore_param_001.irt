--TEST--
001: VSTORE of a PARAM (single use) into a var declares and assigns it (-O0)
--ARGS--
-O0 --emit-c
--CODE--
{
	l_1 = START(l_5);
	int32_t x = PARAM(l_1, "x", 1);
	int32_t d_2 = VAR(l_1, "v");
	l_3 = VSTORE(l_1, d_2, x);
	int32_t d_4, l_4 = VLOAD(l_3, d_2);
	l_5 = RETURN(l_4, d_4);
}
--EXPECT--
int32_t test(int32_t x)
{
	int32_t d_1 = x;
	int32_t v;
	v = d_1;
	return v;
}
