--TEST--
020: FOLD: signed MOD INT32_MIN by minus one not folded
--ARGS--
-O2 --save
--CODE--
{
	int32_t c_1 = -2147483648;
	int32_t c_2 = -1;
	l_1 = START(l_3);
	int32_t d_2 = MOD(c_1, c_2);
	l_3 = RETURN(l_1, d_2);
}
--EXPECT--
{
	uintptr_t c_1 = 0;
	bool c_2 = 0;
	bool c_3 = 1;
	int32_t c_4 = -2147483648;
	int32_t c_5 = -1;
	l_1 = START(l_3);
	int32_t d_2 = MOD(c_4, c_5);
	l_3 = RETURN(l_1, d_2);
}
